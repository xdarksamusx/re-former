<%= form_with model:@user, url: user_path(@user),  method: :patch  do    |form| %>
  <% if @user.errors.any?%>
    <div class="error-messages">
      <h2>
        <%= pluralize(@user.errors.count, "error")%> prohibited this user from being saved
      </h2>
      <ul>
        <% @user.errors.full_messages.each do  |message|%>
          <li> <%= message%> </li>
        <% end%>
      </ul>
    </div>
  <%end%>
  <div>
    <%= form.label :username%>
    <%= form.text_field :username, name: "user[username]"  %>
  </div>
  <div>
    <%= form.label :email%>
    <%= form.email_field :email, name: "user[email]"  %>
  </div>
  <div>
    <%= form.label :password%>
    <%= form.password_field :password,  name:"user[password]"  %>
  </div>
  <%= form.submit "Submit"  %>
<%end%>
